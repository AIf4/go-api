{
    "swagger": "2.0",
    "info": {
        "description": "API REST para gestión de productos estilo MercadoLibre.",
        "title": "Go-Meli API",
        "contact": {},
        "version": "1.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
